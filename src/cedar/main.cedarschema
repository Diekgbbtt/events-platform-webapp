

entity Role;

entity Category;
entity Log;
entity Consent;
entity Purpose;

entity EventsContainer;
entity CategoriesContainer;
entity AdsContainer;


entity Person in Role {
id: Long,
active: Bool,
username: String ,
name: String,
surname: String,
gender: String
};

entity Event {
id: Long,
title: String,
description: String,
person_id: Long,
requesters: Set<Person>
};
